# Site URL (used for Stripe redirects, email links, server-side auth redirects).
# Must match the canonical HTTPS origin users use in production (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://6degree.noemtech.com

# --- Why login works locally but breaks on production ---
# 1) Vercel env: Copy every NEXT_PUBLIC_* and server secret from .env into Vercel → Settings →
#    Environment Variables for **Production**. NEXT_PUBLIC_* is inlined at **build** time — redeploy
#    after changing those vars.
# 2) Supabase → Authentication → URL Configuration:
#    - Site URL = your live app (e.g. https://6degree.noemtech.com), NOT https://xxx.supabase.co
#    - Redirect URLs must include your **production** callback exactly, e.g.
#        https://6degree.noemtech.com/auth/callback
#      and for local dev:
#        http://localhost:3000/auth/callback
#    (OAuth redirectTo is built from the browser origin; Supabase rejects URLs not in this list.)
# 3) Use one canonical host (www OR apex, not both) so PKCE cookies match /auth/callback.
# 4) Google Cloud → OAuth client redirect URI stays:
#        https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback

# Supabase — https://supabase.com/dashboard/project/_/settings/api
# No trailing slash. Google OAuth (Cloud Console) redirect URI must be exactly:
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
# (not the bare https://YOUR_PROJECT_REF.supabase.co — that causes {"error":"requested path is invalid"}.)
#
# Supabase → Authentication → Site URL must be YOUR APP (e.g. https://6degree.noemtech.com), not *.supabase.co.
NEXT_PUBLIC_SUPABASE_URL=
# Use either: legacy “anon” JWT, or the new “publishable” key (dashboard may only show one).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Server-only: never expose to the client. Used for waitlist insert, Stripe webhooks, admin tasks.
SUPABASE_SERVICE_ROLE_KEY=

# Waitlist form → also sends signups via Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=onboarding@resend.dev
CONTACT_TO_EMAIL=you@example.com

# Legacy alias (optional) — some routes fall back to this if NEXT_PUBLIC_SITE_URL is unset
AUTH_URL=https://6degree.noemtech.com

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Stripe Price IDs — create products at dashboard.stripe.com/products
# Current plans:
STRIPE_PRICE_SOLO_MONTHLY=price_xxxxxxxx
STRIPE_PRICE_SOLO_YEARLY=price_xxxxxxxx
STRIPE_PRICE_TEAMS_MONTHLY=price_xxxxxxxx
STRIPE_PRICE_TEAMS_YEARLY=price_xxxxxxxx

# Legacy aliases (optional fallback):
# STRIPE_PRICE_PLUS_MONTHLY=price_xxxxxxxx
# STRIPE_PRICE_PLUS_YEARLY=price_xxxxxxxx
# STRIPE_PRICE_ADVANCED_MONTHLY=price_xxxxxxxx
# STRIPE_PRICE_ADVANCED_YEARLY=price_xxxxxxxx
